{
  "$schema": "https://cdn.jsdelivr.net/gh/webpro/knip@latest/packages/knip/schema.json",
  "entry": ["src/routes/**/*.{ts,tsx}", "src/App.jsx", "src/main.tsx"],
  "project": ["src/**/*.{ts,tsx,js,jsx}"],
  "ignore": [".next", ".turbo", ".cache", "dist", "build", "coverage", "node_modules"],
  "ignoreExports": [
    "default",
    "metadata",
    "generateMetadata",
    "generateStaticParams",
    "generateImageMetadata",
    "GET",
    "POST",
    "PUT",
    "DELETE",
    "PATCH",
    "HEAD",
    "OPTIONS"
  ],
  "ignorePatterns": ["**/*.config.*", "**/*.d.ts", "**/dist/**"],
  "workspaces": {
    ".": {
      "entry": ["src/**/*.entry.ts"],
      "ignore": ["node_modules/**"]
    }
  }
}
